        <td><div class="btn-group"><a class="btn btn-pieza" href="#">[Ver pieza]</a></div></td>
      </tr>
    </tbody>
  </table>
</div>

<!-- ══════════ JUEVES ══════════ -->
<div class="day-section">
  <div class="day-header">
    <div class="day-name">Jueves</div>
    <div class="day-count">2 piezas</div>
    <div class="day-line"></div>
  </div>

  <table class="content-table">
    <thead>
      <tr>
        <th class="col-plat">Plataforma</th>
        <th class="col-tipo">Tipo</th>
        <th class="col-idea">Idea / Concepto</th>
        <th class="col-caption">Caption</th>
        <th class="col-ref">Referencias</th>
        <th class="col-guion">Guión</th>
        <th class="col-pieza">Pieza</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><span class="plat plat-tt">TikTok</span></td>
        <td><span class="tipo tipo-light">Light</span><br><span style="font-size:10px;color:var(--text3)">Trend · texto</span></td>
