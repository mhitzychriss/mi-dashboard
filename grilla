<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grilla Optimizada — Mhitzy Chriss</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0d0d0f; --bg2:#141416; --bg3:#1c1c1f;
  --border:rgba(255,255,255,0.07); --border2:rgba(255,255,255,0.13);
  --text:#f0eee8; --text2:#9a9890; --text3:#4a4846;
  --accent:#e8855a;

  --heavy-bg:rgba(232,133,90,0.10); --heavy-border:rgba(232,133,90,0.30); --heavy:#e8855a;
  --light-bg:rgba(90,157,232,0.08); --light-border:rgba(90,157,232,0.25); --light:#5a9de8;
  --reuse-bg:rgba(155,125,232,0.08); --reuse-border:rgba(155,125,232,0.25); --reuse:#9b7de8;
  --story-bg:rgba(255,255,255,0.04); --story-border:rgba(255,255,255,0.09); --story:#6a6866;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;line-height:1.6;padding:36px 28px;min-height:100vh}

.header{margin-bottom:32px}
.brand{font-family:'Playfair Display',serif;font-size:11px;font-weight:400;color:var(--accent);letter-spacing:.14em;text-transform:uppercase;margin-bottom:5px}
.title{font-family:'Playfair Display',serif;font-size:32px;font-weight:900;line-height:1.1;margin-bottom:6px}
.subtitle{font-size:12px;color:var(--text2);font-weight:300}

.stats{display:flex;gap:10px;margin-bottom:28px;flex-wrap:wrap}
.stat{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:12px 16px;min-width:100px}
.stat-label{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin-bottom:3px}
.stat-value{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;line-height:1}
.stat-value span{font-size:11px;font-family:'DM Sans',sans-serif;color:var(--text2);font-weight:400}

.legend{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px;padding:14px 16px;background:var(--bg2);border-radius:10px;border:1px solid var(--border)}
.legend-title{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);width:100%;margin-bottom:8px}
.leg{display:flex;align-items:center;gap:7px;font-size:11.5px;color:var(--text2)}
.legdot{width:28px;height:6px;border-radius:3px;flex-shrink:0}
.leg strong{color:var(--text);font-weight:600;font-size:11.5px}

.tabs{display:flex;gap:4px;margin-bottom:22px;background:var(--bg2);padding:4px;border-radius:10px;border:1px solid var(--border);width:fit-content}
.tab{padding:6px 16px;border-radius:7px;font-size:12px;font-weight:500;cursor:pointer;border:none;background:transparent;color:var(--text2);transition:all .2s;font-family:'DM Sans',sans-serif;letter-spacing:.02em}
.tab:hover{color:var(--text)}
.tab.active{background:var(--bg3);color:var(--text);border:1px solid var(--border2)}

.week{display:none}
.week.active{display:block}
.week-label{font-size:10px;font-weight:600;color:var(--accent);letter-spacing:.1em;text-transform:uppercase;margin-bottom:18px;padding-bottom:10px;border-bottom:1px solid var(--border)}

.day-block{margin-bottom:6px;display:grid;grid-template-columns:64px 1fr 1fr;gap:6px;align-items:stretch}
.day-name{display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);background:var(--bg2);border-radius:8px;border:1px solid var(--border);min-height:70px}

.card{border-radius:8px;padding:10px 12px;border:1px solid;position:relative;overflow:hidden}
.card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%}

.card.heavy{background:var(--heavy-bg);border-color:var(--heavy-border)}
.card.heavy::before{background:var(--heavy)}
.card.light{background:var(--light-bg);border-color:var(--light-border)}
.card.light::before{background:var(--light)}
.card.reuse{background:var(--reuse-bg);border-color:var(--reuse-border)}
.card.reuse::before{background:var(--reuse)}
.card.story{background:var(--story-bg);border-color:var(--story-border)}
.card.story::before{background:var(--story)}

.card-top{display:flex;align-items:center;gap:6px;margin-bottom:5px}
.type-badge{font-size:9px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:2px 6px;border-radius:3px;white-space:nowrap;flex-shrink:0}
.heavy .type-badge{background:rgba(232,133,90,0.2);color:var(--heavy)}
.light .type-badge{background:rgba(90,157,232,0.2);color:var(--light)}
.reuse .type-badge{background:rgba(155,125,232,0.2);color:var(--reuse)}
.story .type-badge{background:rgba(255,255,255,0.06);color:var(--text2)}

.platform{font-size:9px;font-weight:600;color:var(--text3);letter-spacing:.05em;text-transform:uppercase}

.card-title{font-size:11.5px;font-weight:600;line-height:1.35;margin-bottom:3px;color:var(--text)}
.heavy .card-title{color:#f0a882}
.light .card-title{color:#8ab8f0}
.reuse .card-title{color:#b8a0f0}

.card-body{font-size:10.5px;font-weight:300;line-height:1.45;color:var(--text2)}
.card-hook{font-style:italic;font-size:10px;color:var(--text3);margin-top:4px;font-family:'Playfair Display',serif;line-height:1.3}

.star-badge{display:inline-block;font-size:9px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;padding:1px 6px;border-radius:3px;background:var(--accent);color:#fff;margin-bottom:4px}

/* ── Week 1 enhanced card layout ── */
.card-tags{font-size:9.5px;color:var(--text3);margin-top:3px;font-weight:400;letter-spacing:.02em}
.card-section{margin-top:8px;padding-top:8px;border-top:1px solid rgba(255,255,255,0.06)}
.card-section-label{font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:4px}
.card-field{width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:5px;padding:6px 8px;font-size:10.5px;color:var(--text2);font-family:'DM Sans',sans-serif;resize:vertical;min-height:36px;line-height:1.4;outline:none;transition:border-color .15s}
.card-field:focus{border-color:rgba(255,255,255,0.2);color:var(--text)}
.card-field::placeholder{color:var(--text3);font-style:italic}
.card-actions{display:flex;gap:6px;margin-top:8px;flex-wrap:wrap}
.btn-action{font-size:10px;font-weight:600;letter-spacing:.04em;padding:5px 10px;border-radius:5px;border:1px solid;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s;text-decoration:none;display:inline-flex;align-items:center;gap:4px}
.btn-script{background:rgba(232,133,90,0.1);border-color:rgba(232,133,90,0.3);color:#e8855a}
.btn-script:hover{background:rgba(232,133,90,0.2);border-color:rgba(232,133,90,0.5)}
.btn-graphic{background:rgba(90,157,232,0.1);border-color:rgba(90,157,232,0.3);color:#5a9de8}
.btn-graphic:hover{background:rgba(90,157,232,0.2);border-color:rgba(90,157,232,0.5)}
.story-pill{display:inline-block;font-size:10px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.09);border-radius:4px;padding:3px 8px;color:var(--text2);margin-top:4px;font-style:italic}

/* Week 1 uses vertical single-column cards per day */
.day-block-v1{margin-bottom:10px}
.day-block-v1 .day-header{display:flex;align-items:center;gap:10px;margin-bottom:6px}
.day-block-v1 .day-name-v1{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);background:rgba(232,133,90,0.08);border:1px solid rgba(232,133,90,0.2);border-radius:6px;padding:4px 10px;white-space:nowrap}
.day-block-v1 .day-divider{flex:1;height:1px;background:var(--border)}
.cards-col{display:flex;flex-direction:column;gap:6px}

@media(max-width:600px){
  body{padding:20px 14px}
  .title{font-size:24px}
  .day-block{grid-template-columns:44px 1fr;grid-template-rows:auto auto}
  .day-block .card:last-child{grid-column:2}
}
</style>
</head>
