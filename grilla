    <div class="leg"><span class="legchip tipo-heavy">Heavy</span> Video grabado y editado</div>
    <div class="leg"><span class="legchip tipo-light">Light</span> Trend / audio viral / rápido</div>
    <div class="leg"><span class="legchip tipo-carousel">Carrusel</span> Diseño estático en Canva</div>
    <div class="leg"><span class="legchip tipo-story">Historia</span> Story / sin producción</div>
  </div>
</div>

<!-- ══════════ LUNES ══════════ -->
<div class="day-section">
  <div class="day-header">
    <div class="day-name">Lunes</div>
    <div class="day-count">3 piezas</div>
    <div class="day-line"></div>
  </div>

  <table class="content-table">
    <thead>
      <tr>
        <th class="col-plat">Plataforma</th>
